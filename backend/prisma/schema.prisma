generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// --- CORE ENTITIES ---
model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  domain    String?  @unique
  createdAt DateTime @default(now())
  clients   Client[]
}

model Client {
  id           String            @id 
  email        String            @unique
  name         String
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime          @default(now())
  templates    Template[]
  signatures   SignatureRecord[]
}

model LegalReviewer {
  id           String            @id 
  email        String            @unique
  name         String
  barNumber    String?
  createdAt    DateTime          @default(now())
  assignedDocs Template[]
  signatures   SignatureRecord[]
}

model Admin {
  id        String   @id 
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
}

// --- AUTHENTICATION ---
model Credential {
  id        String   @id @default(uuid())
  userId    String   @unique // Maps to ClientID, ReviewerID, or AdminID
  role      String   // 'CLIENT', 'LEGAL_REVIEWER', 'ADMIN'
  password  String   // Store hashed passwords here in prod
  updatedAt DateTime @updatedAt
}

// --- LEDGER & STATE ---
model Template {
  id           String              @id @default(uuid())
  content      String              @db.Text
  status       String              // "pending_ai_flags" -> "pending_legal" -> "pending_ai_redrafts" -> "pending_client_action" -> "approved"
  title        String
  documentType String
  clientId     String
  client       Client              @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewerId   String?
  reviewer     LegalReviewer?      @relation(fields: [reviewerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  flags        LegalFlag[]
  redrafts     RedraftedTemplate[]
  auditLogs    AuditLog[]
  signatures   SignatureRecord[]
}

model LegalFlag {
  id          String   @id @default(uuid())
  templateId  String
  cfr_section String
  explanation String   @db.Text
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model RedraftedTemplate {
  id         String   @id @default(uuid())
  templateId String
  modContent String   @db.Text
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  templateId String
  actorId    String
  actorType  String
  prevState  String?
  newState   String
  details    String?  @db.Text
  createdAt  DateTime @default(now())
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model SignatureRecord {
  id               String         @id @default(uuid())
  templateId       String
  action           String
  clientId         String?
  client           Client?        @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewerId       String?
  reviewer         LegalReviewer? @relation(fields: [reviewerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  printedName      String
  signatureMeaning String
  documentHash     String
  ipAddress        String?
  userTrace        String?
  signedAt         DateTime       @default(now())
  template         Template       @relation(fields: [templateId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}